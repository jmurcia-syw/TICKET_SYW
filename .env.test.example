# Plantilla de variables para el ambiente de TEST (Docker Compose aislado, spec 027).
# Uso: cp .env.test.example .env.test   (luego completar los valores reales — nunca commitear .env.test)
#      docker compose -p sywork_test --env-file .env.test up --build -d

# Namespacing de contenedores/red/volumen para este ambiente (NO tocar el default de Desarrollo)
CONTAINER_SUFFIX=_test

# Puertos publicados en el host (distintos de Desarrollo y de Producción)
FRONTEND_PORT=8080
BACKEND_PORT=3001
POSTGRES_PORT=5433
REDIS_PORT=6380

# Base de datos (obligatorias — sin default, docker-compose falla explícito si faltan)
POSTGRES_DB=sywork_tickets_test
POSTGRES_USER=sywork_test
POSTGRES_PASSWORD=CAMBIAR_ESTA_PASSWORD

# Secretos de aplicación (obligatorios — sin default)
JWT_SECRET=CAMBIAR_ESTE_SECRETO

# OAuth Google (opcional, dejar "not-set" si no aplica en Test)
GOOGLE_CLIENT_ID=not-set
GOOGLE_CLIENT_SECRET=not-set

# Backend
FLASK_ENV=production
APP_ENV=test
DEV_SKIP_AUTH=false
FRONTEND_URL=http://localhost:8080

# SMTP (opcional, dejar vacío si no aplica en Test)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@sywork.net

# Frontend
VITE_API_URL=http://localhost:3001
VITE_APP_ENV=test

# Zona horaria (regional)
TZ=America/Bogota
