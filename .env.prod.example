# Plantilla de variables para el ambiente de PRODUCCIÓN (Docker Compose aislado, spec 027).
# Uso: cp .env.prod.example .env.prod   (luego completar con secretos reales — nunca commitear .env.prod)
#      docker compose -p sywork_prod --env-file .env.prod up --build -d
#
# Los puertos abajo son el mapeo interno de Docker Compose, no la exposición final HTTPS al
# usuario — la terminación TLS/proxy inverso sigue pendiente (TODO(HOSTING) en la Constitución).

# Namespacing de contenedores/red/volumen para este ambiente (NO tocar el default de Desarrollo)
CONTAINER_SUFFIX=_prod

# Puertos publicados en el host (los "principales", iguales a los de Desarrollo hoy)
FRONTEND_PORT=80
BACKEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Base de datos (obligatorias — sin default, docker-compose falla explícito si faltan)
POSTGRES_DB=sywork_tickets
POSTGRES_USER=sywork_prod
POSTGRES_PASSWORD=CAMBIAR_ESTA_PASSWORD

# Secretos de aplicación (obligatorios — sin default)
JWT_SECRET=CAMBIAR_ESTE_SECRETO

# OAuth Google
GOOGLE_CLIENT_ID=CAMBIAR_ESTE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CAMBIAR_ESTE_CLIENT_SECRET

# Backend
FLASK_ENV=production
APP_ENV=production
DEV_SKIP_AUTH=false
FRONTEND_URL=http://localhost:80

# SMTP
SMTP_HOST=CAMBIAR_HOST_SMTP
SMTP_PORT=587
SMTP_USER=CAMBIAR_USER_SMTP
SMTP_PASSWORD=CAMBIAR_PASSWORD_SMTP
SMTP_FROM=no-reply@sywork.net

# Frontend
VITE_API_URL=http://localhost:3000
VITE_APP_ENV=production

# Zona horaria (regional)
TZ=America/Bogota
