# Copia este archivo como .env y completa los valores reales
POSTGRES_DB=sywork_tickets
POSTGRES_USER=sywork
POSTGRES_PASSWORD=changeme_strong_password

JWT_SECRET=changeme_jwt_secret_at_least_32_chars

# Obtén estos en console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

FLASK_ENV=development
FLASK_APP=backend/app.py
